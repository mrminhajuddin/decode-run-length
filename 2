def run_length_decode(s):
    result = []
    i = 0

    while i < len(s):
        char = s[i]
        i += 1
        count = ""

        while i < len(s) and s[i].isdigit():
            count += s[i]
            i += 1

        result.append(char * int(count))

    return "".join(result)


# Example
print(run_length_decode("a3b2c1d3"))  # aaabbcddd
